{
  "permissions": {
    "allow": [
      "Bash(npm run build:*)",
      "Bash(npm run build)",
      "Bash(npm start)",
      "Bash(npm install:*)",
      "mcp__Claude_Preview__preview_screenshot",
      "mcp__Claude_Preview__preview_console_logs"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/pre-write-ip-guard.js" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/post-edit-rebuild.js" }
        ]
      }
    ]
  }
}
