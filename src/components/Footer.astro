---
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-3 py-10 px-8 md:px-16 lg:px-24">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row
                items-center justify-between gap-4">

        <p class="font-mono text-2xs text-muted tracking-widest uppercase">
            © {year} Yu-Chin Chan
        </p>

        <div class="flex gap-6">
            <a href="https://github.com/lychan110" target="_blank" rel="noopener"
               class="font-mono text-2xs text-muted hover:text-teal
                      tracking-widest uppercase transition-colors">
                GitHub
            </a>
            <a href="https://linkedin.com/in/lychan" target="_blank" rel="noopener"
               class="font-mono text-2xs text-muted hover:text-teal
                      tracking-widest uppercase transition-colors">
                LinkedIn
            </a>
            <a href="https://scholar.google.com/citations?user=ZK2gpWYAAAAJ" target="_blank" rel="noopener"
               class="font-mono text-2xs text-muted hover:text-teal
                      tracking-widest uppercase transition-colors">
                Scholar
            </a>
        </div>

    </div>
</footer>
