---
// Publications ledger — reads from public/data/publications.json generated at build.
// Designed to be rendered in a <slot name="publications"> inside About.astro.
let pubs: any[] = [];
try {
    const raw = await import('../../public/data/publications.json');
    pubs = (raw.default ?? []).sort((a: any, b: any) => b.year - a.year);
} catch {
    // JSON not yet generated — populated on first build
}
---

<section id="publications" class="px-page pt-[48px] pb-[40px] border-t border-ink border-b border-rule">
    <div class="flex items-baseline justify-between mb-[28px]">
        <h2
            class="font-display font-normal text-ink m-0"
            style="font-size: 44px; letter-spacing: -0.8px;"
        >
            Selected <em>publications.</em>
        </h2>
        <span class="kicker">§ 02 / 04</span>
    </div>

    {pubs.length === 0 ? (
        <p class="font-mono text-[12px] opacity-60">
            Run <code>npm run build</code> to generate publications from .bib
        </p>
    ) : (
        <div>
            {pubs.map((pub: any, i: number) => (
                <div
                    class="ledger-row"
                    style="grid-template-columns: 56px 1fr 1fr;"
                >
                    <!-- Year -->
                    <span
                        class={`font-mono text-[12px] tracking-[0.1em] ${String(pub.year) === '2026' ? 'text-teal' : ''}`}
                        style="font-variant-numeric: tabular-nums;"
                    >
                        {pub.year}
                    </span>

                    <!-- Title + authors -->
                    <div>
                        {(pub.url || pub.doi) ? (
                            <a
                                href={pub.url || `https://doi.org/${pub.doi}`}
                                target="_blank"
                                rel="noopener"
                                class="font-display font-medium block leading-[1.15]
                                       text-ink hover:text-teal transition-colors no-underline"
                                style="font-size: 22px; letter-spacing: -0.2px;"
                            >
                                {pub.title}
                            </a>
                        ) : (
                            <span
                                class="font-display font-medium block leading-[1.15]"
                                style="font-size: 22px; letter-spacing: -0.2px;"
                            >
                                {pub.title}
                            </span>
                        )}
                        <span class="font-mono text-[10px] tracking-[0.1em] opacity-60 mt-[6px] block">
                            {pub.authors}
                        </span>
                    </div>

                    <!-- Venue -->
                    <span class="font-body text-[14px] italic opacity-80 self-start pt-[3px]">
                        {pub.venue}
                    </span>
                </div>
            ))}
        </div>
    )}
</section>
