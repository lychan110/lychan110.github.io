---
// Reads publications.json generated by scripts/parse-bib.js at build time
// Falls back gracefully if the JSON doesn't exist yet

let pubs: any[] = [];
try {
    const raw = await import('../../public/data/publications.json');
    pubs = raw.default ?? [];
} catch {
    // JSON not yet generated — will be populated on first build
}
---

<section id="publications" class="py-24 px-8 md:px-16 lg:px-24 max-w-4xl mx-auto">
    <div class="section-rule mb-12">
        <h2 class="font-display text-4xl text-paper mb-1">Publications</h2>
        <p class="font-mono text-2xs tracking-widest uppercase text-muted">
            Selected works
        </p>
    </div>

    {pubs.length === 0 ? (
        <p class="text-muted font-mono text-sm">
            <!-- Run `npm run build` to generate publications from .bib -->
            Publications load from <code>public/data/publications.json</code>.
            Run <code>npm run build</code> to generate.
        </p>
    ) : (
        <ul class="flex flex-col gap-6">
            {pubs.map((pub: any) => (
                <li class="pub-entry py-1">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            {(pub.url || pub.doi) ? (
                                <a
                                    href={pub.url || `https://doi.org/${pub.doi}`}
                                    target="_blank"
                                    rel="noopener"
                                    class="font-display text-lg text-paper hover:text-teal
                                           transition-colors leading-snug"
                                >
                                    {pub.title}
                                </a>
                            ) : (
                                <span class="font-display text-lg text-paper leading-snug">
                                    {pub.title}
                                </span>
                            )}
                            <p class="text-muted text-sm mt-1">
                                {pub.authors} · <em>{pub.venue}</em> · {pub.year}
                            </p>
                        </div>
                        <span class="font-mono text-2xs text-muted shrink-0 mt-1">
                            {pub.year}
                        </span>
                    </div>
                </li>
            ))}
        </ul>
    )}
</section>
