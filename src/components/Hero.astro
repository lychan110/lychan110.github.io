---
// Hero — full viewport, name + tagline, scroll cue
---

<section
    id="hero"
    class="relative min-h-screen flex flex-col justify-center
           px-8 md:px-16 lg:px-24 pt-24 pb-16"
    style="background-image: url('/assets/img/IMG_20180922_162555.jpg'); background-size: cover; background-position: center;"
>
    <!-- Background noise texture overlay -->
    <div class="absolute inset-0 bg-noise opacity-40 pointer-events-none" />

    <!-- Subtle grid lines -->
    <div class="absolute inset-0 pointer-events-none"
         style="background-image: linear-gradient(rgba(140,193,219,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(140,193,219,0.03) 1px, transparent 1px); background-size: 60px 60px;">
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-3xl animate-stagger">
        <p class="font-mono text-2xs tracking-widest uppercase text-teal mb-6">
            Research Scientist
        </p>

        <h1 class="font-display font-light text-6xl md:text-8xl lg:text-9xl
                   text-paper leading-none tracking-tight mb-8">
            Yu-Chin<br />
            <span class="italic text-paper/50">Chan</span>
        </h1>

        <p class="text-muted text-base md:text-lg max-w-lg leading-relaxed mb-12">
            ML, physics simulation, and engineering design.
            Building tools that make complex systems tractable.
        </p>

        <div class="flex gap-6 items-center">
            <a href="/projects"
               class="font-mono text-2xs tracking-widest uppercase
                      text-teal border border-teal/40 px-5 py-2.5
                      hover:bg-teal/10 transition-colors duration-200">
                View Projects
            </a>
            <a href="#about"
               class="font-mono text-2xs tracking-widest uppercase
                      text-muted hover:text-paper transition-colors duration-200">
                About ↓
            </a>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2
                flex flex-col items-center gap-2 text-muted/40">
        <div class="w-px h-12 bg-gradient-to-b from-transparent to-teal/40
                    animate-pulse" />
    </div>
</section>
