---
// Nav — sticky, backdrop-blurred. Pass current="about"|"projects"|"publications" to activate underline.
interface Props {
    current?: 'about' | 'projects' | 'publications';
}
const { current } = Astro.props;
---

<nav
    class="sticky top-0 z-50 flex items-center justify-between px-page py-[22px] border-b border-rule"
    style="background: var(--color-nav-bg); backdrop-filter: blur(6px);"
>
    <!-- Logo -->
    <a
        href="/"
        class="font-display text-[22px] font-medium tracking-[-0.3px] text-ink
               no-underline hover:text-teal transition-colors duration-150"
    >
        Yu-Chin Chan
    </a>

    <!-- Right side: nav links + theme toggle -->
    <div class="flex items-center gap-1">
        <ul class="flex items-center gap-1 list-none m-0 p-0">
            <li>
                <a href="/" class={`nav-item ${current === 'about' ? 'active' : ''}`}>
                    About
                </a>
            </li>
            <li>
                <a href="/projects" class={`nav-item ${current === 'projects' ? 'active' : ''}`}>
                    Projects
                </a>
            </li>
            <li>
                <a href="/#publications" class={`nav-item ${current === 'publications' ? 'active' : ''}`}>
                    Publications
                </a>
            </li>
        </ul>

        <!-- Theme toggle -->
        <button
            id="theme-toggle"
            aria-label="Toggle theme"
            style="background:none;border:none;cursor:pointer;padding:4px 10px;
                   font-size:14px;opacity:0.55;transition:opacity 150ms;
                   color:var(--color-ink);"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.55'"
        >
            <span id="theme-icon">&#9790;</span>
        </button>
    </div>
</nav>

<script>
    const btn = document.getElementById('theme-toggle') as HTMLButtonElement;
    const icon = document.getElementById('theme-icon') as HTMLSpanElement;
    const html = document.documentElement;

    function syncIcon() {
        // ☾ = go dark, ☀ = go light
        icon.textContent = html.classList.contains('dark') ? '☀' : '☾';
    }

    syncIcon();

    btn.addEventListener('click', () => {
        const isDark = html.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        syncIcon();
    });
</script>
