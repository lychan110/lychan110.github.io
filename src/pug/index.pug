doctype html
head
  meta(charset='utf-8')
  meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
  meta(name='description' content=cv.site.description)
  meta(name='author' content=cv.site.author)
  title= cv.site.title
  link(rel='icon' type='image/x-icon' href='assets/img/favicon.ico')
  // Font Awesome icons (free version)
  script(src='https://use.fontawesome.com/releases/v5.13.0/js/all.js' crossorigin='anonymous')
  // Google fonts
  link(rel='preconnect' href='https://fonts.googleapis.com')
  link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)
  link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Lato&family=Montserrat&family=Nunito:wght@200;300;400;600;700;800;900&family=Roboto:wght@100;300;400;500;700&family=Varela+Round&display=swap')
  // Core theme CSS (includes Bootstrap)
  link(href='css/styles.css' rel='stylesheet')
// Navigation
nav#mainNav.navbar.navbar-expand-lg.navbar-expand-md.navbar-light.fixed-top
  .container
    a.navbar-brand.js-scroll-trigger(href='#page-top') HOME
    button.navbar-toggler.navbar-toggler-right(type='button' data-toggle='collapse' data-target='#navbarResponsive' aria-controls='navbarResponsive' aria-expanded='false' aria-label='Toggle navigation')
      i.fas.fa-bars
    #navbarResponsive.collapse.navbar-collapse
      ul.navbar-nav.ml-auto
        li.nav-item
          a.nav-link.js-scroll-trigger(href='#about') about
        li.nav-item
          a.nav-link.js-scroll-trigger(href='#pubs') publications
        li.nav-item
          a.nav-link.js-scroll-trigger(href='#projects') projects
        li.nav-item
          a.nav-link.js-scroll-trigger(href='#foot') links
// Masthead
header.masthead
  #header-container.container.d-flex.h-100.align-items-center
    .mx-auto.text-center
      h1.mx-auto.my-0.text-uppercase= cv.site.title
      h2.text-white-50.mx-auto.mt-4.mb-4!= cv.site.tagline
      a.btn.btn-link.js-scroll-trigger(href='#about')
        i.fa.fa-angle-down
// About
section#about.about-section.text-center.bg-black
  .container
    .row
      .col.my-0
        #cv-summary.sticky-top
          img#avatar.rounded-circle.img-fluid(src=cv.site.avatar)
          h2 About Yu-Chin
          .men
            div
              a.btn.men-but(data-toggle='collapse' aria-expanded='false' aria-controls='collapse-1' href='#collapse-1' role='button') Go to...
              #collapse-1.collapse.text-uppercase
                p
                  a.men-link.js-scroll-trigger(href='#interests') Interests
                p
                  a.men-link.js-scroll-trigger(href='#edu') Education
                p
                  a.men-link.js-scroll-trigger(href='#awards') Awards
                p
                  a.men-link.js-scroll-trigger(href='#exp') Experience
                p
                  a.men-link.js-scroll-trigger(href='#talks') Talks
                p
                  a.men-link.js-scroll-trigger(href='#pubs') Publications
      #cv-main.col-lg-8.mx-auto
        p.text-justify.men-par!= cv.about
        if cv.notice
          p.text-justify.men-par!= cv.notice
        // Education
        #edu.cv-left.justify-content-center.text-left.no-gutters
          h4 Education
          .card-deck
            each edu in cv.education
              .card
                .card-body.text-left
                  h6= edu.institution
                  .small.text-white-50
                    = edu.degree
                    br
                    = edu.dates
                    if edu.notes
                      each note in edu.notes
                        br
                        = note
        // Awards
        #awards.cv-right.justify-content-center.text-right.no-gutters
          h4 Awards
          .card-deck
            each award in cv.awards
              .card
                .card-body.text-right
                  h6= award.title
                  .small.text-white-50
                    | #{award.source},
                    br
                    = award.date
        // Experience
        #exp.pubs-section.cv-left.justify-content-center.text-left.no-gutters
          h4 Experience
          ul
            each exp in cv.experience
              li
                h6= exp.title
                .small.text-white-50
                  = exp.dates
                  br
                  = exp.summary
        // Talks
        #talks.pubs-section.cv-right.justify-content-center.text-left.no-gutters
          h4 Talks
          ul
            each talk in cv.talks
              li
                h6= talk.title
                .small.text-white-50
                  em= talk.venue
                  if talk.location
                    | , #{talk.location}
                  | , #{talk.date}.
        // Publications (rendered from bib via bibtex-js)
        #pubs.pubs-section.cv-left.justify-content-center.text-left.no-gutters
          h4 Publications
          .bibtex_structure
            .sort.year(extra='DESC number')
              .templates
          #bibtex_display
            .if.bibtex_template(style='display: none;')
              ul
                li
                  .if.url
                    a.bibtexVar(href='+URL+' target='_blank' extra='url')
                      h6
                        span.title
                  .if(class='!url')
                    .if.doi
                      a.bibtexVar(href='http://dx.doi.org/+DOI+' target='_blank' extra='doi')
                        h6
                          span.title
                    .if(class='!doi')
                      h6
                        span.title
                  .small.text-white-50
                    span.author(max='4')
                      span.last
                      span.first_initial ,
                    | ,
                    span.if.journal
                      em
                        span.journal
                      | ,
                    span.if.booktitle
                      | In
                      em
                        span.booktitle
                      | ,
                    span.if.institution
                      span.institution
                      | ,
                    span.if.volume
                      span.volume
                      | ,
                    span.if.journal.number
                      | (
                      span.number
                      | ),
                    span.if.month
                      span.month
                      | ,
                    span.if.year
                      span.year
                      | .
                    span.if.note
                      span.note
                      | .
// Projects
section#projects.projects-section.bg-black
  .container
    h4 Projects
    each project, idx in projects
      - var isRight = project.align === 'right'
      .row.justify-content-center.no-gutters(class=idx < projects.length - 1 ? 'mb-5 mb-lg-0' : '')
        .col-lg-6(class=isRight ? 'order-lg-first' : '')
          img.img-fluid(src=project.image alt=project.title)
        .col-lg-6
          .bg-black.text-center.h-100.project
            .d-flex.h-100
              .project-text.w-100.my-auto(class=isRight ? 'text-center text-lg-right' : 'text-center text-lg-left')
                h4.text-white= project.title
                p.mb-0.text-white-50= project.body
                if isRight
                  hr.d-none.d-lg-block.mb-0.mr-0
                else
                  hr.d-none.d-lg-block.mb-0.ml-0
// Footer
#foot.footer-dark
  .container
    .row
      .col.item.social
        each link in cv.links
          a(data-bs-hover-animate='swing' href=link.url target='_blank')
            i(class=link.icon)
    p.copyright &copy; #{cv.site.author} #{cv.site.copyright_year}
// Bootstrap core JS
script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery/3.5.1/jquery.min.js')
script(src='https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/js/bootstrap.bundle.min.js')
// Third party plugin JS
script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery-easing/1.4.1/jquery.easing.min.js')
// Core theme JS
script(src='js/scripts.js')
script(src='js/custom_cv.js')
script(src='js/bs-animation.js')
script(src='js/vendor/bibtex_js.js')
bibtex(src='assets/ychan_pubs.bib')
