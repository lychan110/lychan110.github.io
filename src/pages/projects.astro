---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProjectGrid from '../components/ProjectGrid';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects
    .map(p => ({ slug: p.slug, ...p.data }))
    .sort((a, b) => b.date.localeCompare(a.date));

const count = String(projects.length).padStart(3, '0');
---

<Base title="Projects — Yu-Chin Chan">
    <Nav current="projects" />
    <main>
        <!-- Masthead -->
        <div class="px-page pt-[56px] pb-[28px]">
            <p class="kicker mb-[14px]">— Catalog № 001 — {count}</p>
            <h1
                class="font-display font-normal leading-[0.95] m-0"
                style="font-size: 88px; letter-spacing: -1.8px;"
            >
                Projects, <em>indexed.</em>
            </h1>
        </div>

        <!-- React island: filterable ledger -->
        <div class="px-page pb-[48px]">
            <ProjectGrid client:load projects={projects} />
        </div>
    </main>
    <Footer />
</Base>
